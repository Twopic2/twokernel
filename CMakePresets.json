{
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20
    },
    "configurePresets": [
        {
            "name": "general-debug-build",
            "binaryDir": "${sourceDir}/build/general-debug-build",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_COMPILE_WARNING_AS_ERROR": "ON",
                "SANITIZER_FLAGS": "-fsanitize=address -fsanitize=undefined -fno-omit-frame-pointer",
                "PROJECT_SRC_DIR": "${sourceDir}/src/"
            }
        },
        {
            "name": "general-release-build",
            "binaryDir": "${sourceDir}/build/general-release-build",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_COMPILE_WARNING_AS_ERROR": "ON",
                "PROJECT_SRC_DIR": "${sourceDir}/src/"
            }
        }
    ]
}